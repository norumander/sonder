# Stage 1: Build
FROM node:20-slim AS build

WORKDIR /app

ARG VITE_GOOGLE_CLIENT_ID=""
ARG VITE_API_URL=""

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .
RUN VITE_GOOGLE_CLIENT_ID=${VITE_GOOGLE_CLIENT_ID} VITE_API_URL=${VITE_API_URL} npm run build

# Stage 2: Serve with nginx
FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html
# Default SPA config (docker-compose.prod.yml overrides via volume mount)
COPY nginx.railway.conf /etc/nginx/conf.d/default.conf
