# Database (overridden by docker-compose for containerized runs)
SONDER_DATABASE_URL=postgresql+asyncpg://sonder:sonder@localhost:5433/sonder

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
SONDER_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT — set to a random string in production
SONDER_JWT_SECRET=change-this-to-a-random-secret

# CORS
SONDER_CORS_ORIGINS=["http://localhost:5173"]

# Frontend — API URL (set automatically in docker-compose)
VITE_API_URL=http://localhost:8000
